<body>

<!-- ===== HEADER / NAV ===== -->
<header class="site-header" id="site-header" role="banner">
  <div class="container header-inner">
    <a href="#home" class="logo" aria-label="Atmos Dental &amp; Aesthetic Clinic home">
      <svg class="logo-svg" width="200" height="52" viewBox="0 0 200 52" fill="none" aria-hidden="true">
        <defs>
          <linearGradient id="toothLogoGrad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#00C9A7"/>
            <stop offset="100%" stop-color="#0077CC"/>
          </linearGradient>
        </defs>
        <!-- Tooth outline shape -->
        <path d="M6 5 C2 5 0 10 0 18 C0 26 2 33 6 38 L8 44 C9 47 11 48 13 47 C15 46 16 44 17 41 C17 41 18 44 19 47 C20 50 22 51 24 50 C26 49 27 46 28 43 L30 37 C34 32 36 25 36 18 C36 10 34 5 30 5 Z" fill="none" stroke="url(#toothLogoGrad)" stroke-width="2.8" stroke-linejoin="round"/>
        <path d="M9 8 C6 11 4 14 4 18 C4 23 6 29 9 34" stroke="#0077CC" stroke-width="1.2" fill="none" opacity="0.45" stroke-linecap="round"/>
        <!-- ATMOS text -->
        <text x="44" y="24" font-family="Arial Black, Helvetica Neue, sans-serif" font-weight="900" font-size="21" fill="white" letter-spacing="2.5">ATMOS</text>
        <!-- DENTAL & AESTHETIC CLINIC text -->
        <text x="45" y="38" font-family="Arial, Helvetica, sans-serif" font-weight="700" font-size="9" fill="#00C9A7" letter-spacing="1.8">DENTAL &amp; AESTHETIC CLINIC</text>
        <!-- Tagline -->
        <text x="45" y="49" font-family="Georgia, serif" font-style="italic" font-size="7.5" fill="rgba(255,255,255,0.55)" letter-spacing="0.5">Transforming Smiles Elevating Lives</text>
      </svg>
    </a>
    <nav class="main-nav" aria-label="Main navigation">
      <ul class="nav-list" role="list">
        <li><a href="#home" class="nav-link active">Home</a></li>
        <li><a href="#about" class="nav-link">About</a></li>
