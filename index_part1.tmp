<main>

<!-- ===== HERO ===== -->
<section class="hero" id="home" aria-label="Hero section">
  <div class="hero-bg" aria-hidden="true"></div>
  <div class="container hero-inner">
    <div class="hero-content fade-in">
      <div class="hero-badge">&#10024; Premium Dental &amp; Aesthetic Care</div>
      <h1 class="hero-title">
        <span class="hero-title-accent">Transforming</span> Smiles,<br/>Elevating Lives
      </h1>
      <p class="hero-sub">Experience world-class dental care with Dr. Mohammed Farooq Mustafa. From smile designing to dental implants &mdash; your dream smile is just one appointment away.</p>
      <div class="hero-actions">
        <a href="https://wa.me/919025408659" class="btn btn-primary btn-lg" target="_blank" rel="noopener">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.117 1.526 5.845L0 24l6.334-1.508A11.95 11.95 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.92 0-3.725-.5-5.293-1.376l-.379-.224-3.93.936.975-3.826-.248-.394A9.956 9.956 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
          Book Appointment
        </a>
        <a href="tel:+919025408659" class="btn btn-outline btn-lg">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          Call Us
        </a>
      </div>
    </div>
    <div class="hero-illustration fade-in-right">
      <div class="hero-3d-tooth">
        <svg viewBox="0 0 200 240" class="tooth-3d-svg" aria-hidden="true">
          <defs>
            <radialGradient id="toothGrad3d" cx="35%" cy="28%" r="65%">
              <stop offset="0%" stop-color="#ffffff"/>
              <stop offset="30%" stop-color="#eef6fc"/>
              <stop offset="70%" stop-color="#cce4f7"/>
              <stop offset="100%" stop-color="#a8ceec"/>
            </radialGradient>
            <radialGradient id="toothShadow3d" cx="50%" cy="60%" r="55%">
              <stop offset="0%" stop-color="rgba(0,119,204,0.35)"/>
              <stop offset="100%" stop-color="rgba(0,119,204,0)"/>
            </radialGradient>
            <radialGradient id="rootGrad" cx="30%" cy="20%" r="80%">
              <stop offset="0%" stop-color="#ddeeff"/>
              <stop offset="100%" stop-color="#b8d4f0"/>
            </radialGradient>
            <filter id="toothGlow3d" x="-20%" y="-20%" width="140%" height="140%">
              <feGaussianBlur stdDeviation="4" result="blur"/>
              <feComposite in="SourceGraphic" in2="blur" operator="over"/>
            </filter>
            <filter id="shadowFilter" x="-10%" y="-10%" width="130%" height="130%">
              <feDropShadow dx="0" dy="8" stdDeviation="10" flood-color="rgba(0,100,200,0.3)"/>
            </filter>
            <linearGradient id="tealAccent" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#00C9A7"/>
              <stop offset="100%" stop-color="#0077CC"/>
            </linearGradient>
          </defs>
          <!-- Outer glow ellipse -->
          <ellipse cx="100" cy="125" rx="88" ry="108" fill="url(#toothShadow3d)" opacity="0.6"/>
          <!-- Main tooth crown shape -->
          <path d="M100 12 C72 12 48 32 38 62 C28 92 33 124 43 148 C52 168 57 188 100 188 C143 188 148 168 157 148 C167 124 172 92 162 62 C152 32 128 12 100 12Z" fill="url(#toothGrad3d)" filter="url(#shadowFilter)"/>
          <!-- Side shading for 3D depth -->
          <path d="M38 62 C28 92 33 124 43 148 C50 165 55 180 70 186" fill="none" stroke="rgba(100,160,220,0.25)" stroke-width="18" stroke-linecap="round"/>
          <!-- Tooth roots -->
          <path d="M76 186 L66 222 Q71 228 77 222 L82 196" fill="url(#rootGrad)" opacity="0.95"/>
          <path d="M100 187 L98 228 Q101 231 104 228 L104 187" fill="url(#rootGrad)" opacity="0.95"/>
          <path d="M124 186 L130 222 Q125 228 121 222 L118 196" fill="url(#rootGrad)" opacity="0.95"/>
          <!-- Root shadows -->
          <path d="M76 195 L68 220" stroke="rgba(100,150,210,0.3)" stroke-width="3" stroke-linecap="round"/>
          <path d="M100 195 L100 226" stroke="rgba(100,150,210,0.3)" stroke-width="3" stroke-linecap="round"/>
          <path d="M124 195 L128 220" stroke="rgba(100,150,210,0.3)" stroke-width="3" stroke-linecap="round"/>
          <!-- Primary highlight shine (large) -->
          <ellipse cx="76" cy="68" rx="20" ry="32" fill="white" opacity="0.55" transform="rotate(-18 76 68)"/>
          <!-- Secondary highlight (small bright) -->
          <ellipse cx="69" cy="56" rx="9" ry="16" fill="white" opacity="0.82" transform="rotate(-18 69 56)"/>
          <!-- Subtle highlight right side -->
          <ellipse cx="130" cy="80" rx="8" ry="14" fill="white" opacity="0.22" transform="rotate(12 130 80)"/>
          <!-- Teal accent line at crown base -->
          <path d="M56 172 Q100 184 144 172" stroke="url(#tealAccent)" stroke-width="3.5" fill="none" stroke-linecap="round"/>
          <!-- Subtle crown detail lines -->
          <path d="M68 145 Q100 152 132 145" stroke="rgba(100,150,200,0.2)" stroke-width="1.5" fill="none" stroke-linecap="round"/>
        </svg>
        <!-- Floating sparkles -->
        <div class="sparkle s1" aria-hidden="true">&#10022;</div>
        <div class="sparkle s2" aria-hidden="true">&#10022;</div>
        <div class="sparkle s3" aria-hidden="true">&#10022;</div>
        <div class="sparkle s4" aria-hidden="true">&#9670;</div>
        <!-- Orbiting teal ring -->
        <div class="tooth-ring" aria-hidden="true"></div>
        <div class="tooth-ring tooth-ring-2" aria-hidden="true"></div>
      </div>
    </div>
  </div>
  <div class="hero-wave" aria-hidden="true">
    <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0,40 C360,80 1080,0 1440,40 L1440,60 L0,60 Z" fill="#ffffff"/>
    </svg>
  </div>
</section>